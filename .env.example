# ============================================================
# NiiRo Smart Wedding - Environment Variables
# Diese Datei als .env.local kopieren und mit echten Werten fuellen.
# ============================================================

# Supabase Projekt-URL (oeffentlich)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (oeffentlich, RLS schuetzt Daten)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Supabase Service Role Key (nur Server)
# Fuer serverseitige RSVP-Schreibzugriffe empfohlen und bei Legacy-Schemas praktisch erforderlich.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hochzeitsdatum in ISO 8601
NEXT_PUBLIC_WEDDING_DATE=2026-11-03T14:00:00+01:00

# RSVP-Deadline in ISO 8601
NEXT_PUBLIC_RSVP_DEADLINE=2026-10-01T23:59:59+02:00

# Kanonische App-URL
NEXT_PUBLIC_APP_URL=https://hochzeit.example.com

# Kompatibilitaetsalias fuer fruehere Task-Beschreibungen
NEXT_PUBLIC_SITE_URL=https://hochzeit.example.com

# Mobile Shell (Capacitor)
# Falls leer, nutzt die Mobile-App NEXT_PUBLIC_APP_URL, sonst den produktiven Live-Stand
CAPACITOR_SERVER_URL=https://smartwedding.niiro.ai
CAPACITOR_HOSTED_APP_URL=https://smartwedding.niiro.ai
# Optional fuer lokale Mobile-Entwicklung gegen localhost
CAPACITOR_ALLOW_LOCALHOST=false
CAPACITOR_APP_START_PATH=/
CAPACITOR_APP_ID=com.niiro.smartwedding
CAPACITOR_APP_NAME=NiiRo Smart Wedding
MOBILE_RELEASES_REPO=robinhopkr/niiro-smart-wedding

# Optional: Maps Embed URL
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=

# Optional: Rate Limit
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=3600000

# Admin E-Mail
ADMIN_EMAIL=admin@example.com

# Admin Passwort fuer den geschuetzten Brautpaar-Login
ADMIN_PASSWORD=change-me

# Optionaler separater Login fuer Wedding Planner mit denselben Rechten
WEDDING_PLANNER_EMAIL=
WEDDING_PLANNER_PASSWORD=

# Optionales zusaetzliches Secret fuer die Admin-Session
ADMIN_SESSION_SECRET=change-me-too

# Optional: taeglicher Retention-Cleanup ueber Vercel Cron
CRON_SECRET=change-me-cron-secret

# Stripe Checkout fuer den kostenpflichtigen Brautpaar-Bereich
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Google Play Billing fuer Android-Store-Releases
GOOGLE_PLAY_PACKAGE_NAME=com.niiro.smartwedding
GOOGLE_PLAY_COUPLE_ACCESS_PRODUCT_ID=niiro_smart_wedding_couple_access
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY=

# Optional: Cloudflare R2 fuer optimierte Galerievarianten
# R2_PUBLIC_BASE_URL nur setzen, wenn dort ausschliesslich oeffentliche Bilder liegen.
# Bei privaten Fotografenbildern im selben Bucket lieber leer lassen, damit signierte URLs genutzt werden.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Optional: OpenAI fuer den Hilfsassistenten im Paarbereich
# Stand 9. Maerz 2026 ist gpt-5.2 das aktuelle offiziell gefundene GPT-5-Modell in der OpenAI-Doku.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.2

# Optional: weitere Ausnahme-Adressen fuer den Billing-Bypass, komma-getrennt
BILLING_BYPASS_EMAILS=robin_kolb@yahoo.com

# Rechtliche Seiten / Pflichtangaben
LEGAL_COMPANY_NAME=
LEGAL_OWNER_NAME=
LEGAL_STREET=
LEGAL_POSTAL_CODE=
LEGAL_CITY=
LEGAL_COUNTRY=Deutschland
LEGAL_PHONE=
LEGAL_EMAIL=
LEGAL_VAT_ID=
LEGAL_REGISTER_COURT=
LEGAL_REGISTER_NUMBER=
LEGAL_RESPONSIBLE_PERSON=
LEGAL_SUPPORT_URL=https://smartwedding.niiro.ai
