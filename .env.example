# ============================================================
# myWed by NiiRo AI - Environment Variables
# Diese Datei als .env.local kopieren und mit echten Werten fuellen.
# ============================================================

# Supabase Projekt-URL (oeffentlich)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (oeffentlich, RLS schuetzt Daten)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Supabase Service Role Key (nur Server)
# Fuer serverseitige RSVP-Schreibzugriffe empfohlen und bei Legacy-Schemas praktisch erforderlich.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hochzeitsdatum in ISO 8601
NEXT_PUBLIC_WEDDING_DATE=2026-11-03T14:00:00+01:00

# RSVP-Deadline in ISO 8601
NEXT_PUBLIC_RSVP_DEADLINE=2026-10-01T23:59:59+02:00

# Kanonische App-URL
NEXT_PUBLIC_APP_URL=https://hochzeit.example.com

# Kompatibilitaetsalias fuer fruehere Task-Beschreibungen
NEXT_PUBLIC_SITE_URL=https://hochzeit.example.com

# Mobile Shell (Capacitor)
# Falls leer, nutzt die Mobile-App NEXT_PUBLIC_APP_URL, sonst den Vercel-Live-Stand
CAPACITOR_SERVER_URL=https://hochzeits-rsvp.vercel.app
CAPACITOR_APP_START_PATH=/demo
CAPACITOR_APP_ID=com.niiro.hochzeitsapp
CAPACITOR_APP_NAME=myWed by NiiRo AI
MOBILE_RELEASES_REPO=robinhopkr/hochzeits-rsvp

# Optional: Maps Embed URL
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=

# Optional: Rate Limit
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=3600000

# Admin E-Mail
ADMIN_EMAIL=admin@example.com

# Admin Passwort fuer den geschuetzten Brautpaar-Login
ADMIN_PASSWORD=change-me

# Optionales zusaetzliches Secret fuer die Admin-Session
ADMIN_SESSION_SECRET=change-me-too

# Stripe Checkout fuer den kostenpflichtigen Brautpaar-Bereich
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: weitere Ausnahme-Adressen fuer den Billing-Bypass, komma-getrennt
BILLING_BYPASS_EMAILS=robin_kolb@yahoo.com
